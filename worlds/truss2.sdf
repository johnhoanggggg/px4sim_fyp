    <!-- x = +3 columns -->
    <model name="col_R_0"><static>true</static>
      <pose>3 0 2.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.1 0.1 5.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.1 0.1 5.5</size></box></geometry>
