<?xml version="1.0" encoding="UTF-8"?>
<sdf version="1.9">
  <world name="truss2">
    <physics type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics">
      <engine><filename>gz-physics-dartsim-plugin</filename></engine>
    </plugin>
    <plugin filename="gz-sim-navsat-system" name="gz::sim::systems::NavSat"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>
    <plugin filename="gz-sim-magnetometer-system" name="gz::sim::systems::Magnetometer"/>
    <plugin filename="gz-sim-air-pressure-system" name="gz::sim::systems::AirPressure"/>

    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type="adiabatic"/>
    <scene>
      <grid>false</grid>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.6 0.7 0.85 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- Ground -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>1 1</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>500 500</size></plane></geometry>
          <material>
            <ambient>0.75 0.75 0.70 1</ambient>
            <diffuse>0.75 0.75 0.70 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!--
      MULTI-LAYER ROOF TRUSS LATTICE
      ===============================
      3 parallel truss planes at x = -3, 0, +3  (ENU)
      6 bays along Y: nodes at y = 0, 2.5, 5, 7.5, 10, 12.5
      Bottom chord z = 1.0,  Top chord z = 5.0
      Flyable zone: z ~ 1.1 to 4.9  (3.8 m vertical clearance)

      Internal cross-beams at various heights create a 3-D maze.
      Beam depth 0.3 m so the drone must actively avoid them.

      ENU -> NED:  ned_north = enu_y, ned_east = enu_x, ned_up = enu_z
    -->

    <!-- ============================================================ -->
    <!--  COLUMNS  (vertical posts at every grid intersection)        -->
    <!--  Grid: x={-3,0,3} x y={0,2.5,5,7.5,10,12.5}               -->
    <!--  Each: 0.1 x 0.1 x 5.5 m, z centre = 2.75                 -->
    <!-- ============================================================ -->

    <!-- x = -3 columns -->
    <model name="col_L_0"><static>true</static>
      <pose>-3 0 2.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.1 0.1 5.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.1 0.1 5.5</size></box></geometry>
          <material><ambient>0.50 0.45 0.35 1</ambient><diffuse>0.50 0.45 0.35 1</diffuse></material></visual>
      </link>
    </model>
    <model name="col_L_1"><static>true</static>
      <pose>-3 2.5 2.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.1 0.1 5.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.1 0.1 5.5</size></box></geometry>
          <material><ambient>0.50 0.45 0.35 1</ambient><diffuse>0.50 0.45 0.35 1</diffuse></material></visual>
      </link>
    </model>
    <model name="col_L_2"><static>true</static>
      <pose>-3 5 2.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.1 0.1 5.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.1 0.1 5.5</size></box></geometry>
          <material><ambient>0.50 0.45 0.35 1</ambient><diffuse>0.50 0.45 0.35 1</diffuse></material></visual>
      </link>
    </model>
    <model name="col_L_3"><static>true</static>
      <pose>-3 7.5 2.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.1 0.1 5.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.1 0.1 5.5</size></box></geometry>
          <material><ambient>0.50 0.45 0.35 1</ambient><diffuse>0.50 0.45 0.35 1</diffuse></material></visual>
      </link>
    </model>
    <model name="col_L_4"><static>true</static>
      <pose>-3 10 2.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.1 0.1 5.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.1 0.1 5.5</size></box></geometry>
          <material><ambient>0.50 0.45 0.35 1</ambient><diffuse>0.50 0.45 0.35 1</diffuse></material></visual>
      </link>
    </model>
    <model name="col_L_5"><static>true</static>
      <pose>-3 12.5 2.75 0 0 0</pose>
      <link name="link">
