          <material><ambient>0.50 0.45 0.35 1</ambient><diffuse>0.50 0.45 0.35 1</diffuse></material></visual>
      </link>
    </model>

    <!-- x = 0 columns -->
    <model name="col_C_0"><static>true</static>
      <pose>0 0 2.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.1 0.1 5.5</size></box></geometry></collision>
