    <!-- ============================================================ -->
    <!--  INTERNAL CROSS-BEAMS  (the 3-D maze obstacles)             -->
    <!--  0.3 m deep beams at various heights inside the structure   -->
    <!--  Colour: dark steel blue to distinguish from chords         -->
    <!-- ============================================================ -->

    <!-- Bay A  (y ~ 1.25):  left bay beam at z=2.5,  right bay beam at z=3.5 -->
    <model name="internal_A_L"><static>true</static>
      <pose>-1.5 1.25 2.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>3.0 0.1 0.3</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>3.0 0.1 0.3</size></box></geometry>
          <material><ambient>0.35 0.35 0.42 1</ambient><diffuse>0.35 0.35 0.42 1</diffuse></material></visual>
      </link>
    </model>
    <model name="internal_A_R"><static>true</static>
      <pose>1.5 1.25 3.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>3.0 0.1 0.3</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>3.0 0.1 0.3</size></box></geometry>
          <material><ambient>0.35 0.35 0.42 1</ambient><diffuse>0.35 0.35 0.42 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Bay B  (y ~ 3.75):  full width at z=2.5 with 1.5 m centre gap -->
    <model name="internal_B_L"><static>true</static>
      <pose>-1.875 3.75 2.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>2.25 0.1 0.3</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>2.25 0.1 0.3</size></box></geometry>
          <material><ambient>0.35 0.35 0.42 1</ambient><diffuse>0.35 0.35 0.42 1</diffuse></material></visual>
      </link>
    </model>
    <model name="internal_B_R"><static>true</static>
      <pose>1.875 3.75 2.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>2.25 0.1 0.3</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>2.25 0.1 0.3</size></box></geometry>
          <material><ambient>0.35 0.35 0.42 1</ambient><diffuse>0.35 0.35 0.42 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Bay C  (y ~ 6.25):  left beam at z=3.5,  right beam at z=2.0 -->
    <model name="internal_C_L"><static>true</static>
